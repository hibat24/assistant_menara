# ==============================================================================
# RAG ASSISTANT BACKEND CONFIGURATION
# ==============================================================================

# Clé API Groq (Remplacer par votre propre clé Groq depuis console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Modèle d'inférence LLM à utiliser sur Groq
GROQ_MODEL=llama-3.3-70b-versatile

# URL de base de l'API de Groq (Compatible OpenAI SDK)
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ------------------------------------------------------------------------------
# SERVEUR API CONFIGURATION (FASTAPI / UVICORN)
# ------------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
